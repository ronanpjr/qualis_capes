# ============================================================================
# QUALIS CAPES — Arquivo de Configuração de Exemplo
# ============================================================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA faça commit de .env com valores de produção!
# Uso: cp .env.example .env
#
# Em Docker Compose, as variáveis são automaticamente carregadas daqui.
# Em produção, use variáveis de ambiente do servidor em vez de arquivo .env.
# ============================================================================

# Google Gemini API
# Obtenha sua chave em: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL Database
POSTGRES_USER=qualis_user
POSTGRES_PASSWORD=your_secure_password_here_change_in_production
POSTGRES_DB=qualis_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Frontend — API URL
# Usado durante build do Vite (npm run build)
# Em desenvolvimento: http://localhost:8000
# Em produção: https://seu-dominio.com/api (sem /api no final, é adicionado automaticamente)
VITE_API_URL=http://localhost:8000

# Produção — CORS Origin
# Domínio onde a aplicação será hospedada (para validação CORS)
# Exemplo: https://seu-dominio.com
PROD_ORIGIN=

# Logging & Debugging
# Níveis: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO